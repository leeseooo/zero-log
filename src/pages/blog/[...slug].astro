---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const catLabel: Record<string, string> = {
  retro: '판단/설계 회고',
  ai: 'AI 협업',
  debug: '삽질/디버깅',
  craft: '감각/검수',
};
---

<BaseLayout title={`${post.data.title} · ZERO LOG`} description={post.data.description}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <span class="post-cat">{catLabel[post.data.category]}</span>
        <time>
          {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <h1 class="display post-h1">{post.data.title}</h1>
      <p class="post-lead">{post.data.description}</p>
      {
        post.data.tags.length > 0 && (
          <ul class="post-tags">
            {post.data.tags.map((t) => (
              <li>#{t}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/blog">← 전체 글</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 140px 44px 0;
  }
  .post-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    color: var(--color-dim);
    font-size: 13px;
    letter-spacing: -0.01em;
    margin-bottom: 20px;
  }
  .post-cat {
    color: var(--color-violet);
  }
  .post-h1 {
    font-size: clamp(34px, 6vw, 58px);
    letter-spacing: -0.05em;
    line-height: 1.05;
  }
  .post-lead {
    margin: 24px 0 0;
    color: var(--color-muted);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.55;
    letter-spacing: -0.02em;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    padding: 0;
    margin: 24px 0 0;
  }
  .post-tags li {
    color: var(--color-dim);
    font-size: 13px;
  }
  .post-footer {
    margin: 64px 0 40px;
    padding-top: 24px;
    border-top: 1px solid #171717;
  }
  @media (max-width: 640px) {
    .post {
      padding: 110px 20px 0;
    }
  }
</style>

<style is:global>
  /* 본문 타이포 — 다크 위 가독성 우선 */
  .prose {
    margin-top: 56px;
    color: #d8d8d8;
    font-size: 17px;
    line-height: 1.75;
    letter-spacing: -0.011em;
    overflow-wrap: break-word;
  }
  .prose :not(pre) > code {
    overflow-wrap: anywhere;
  }
  .prose > * + * {
    margin-top: 1.4em;
  }
  .prose h2 {
    font-size: 28px;
    letter-spacing: -0.04em;
    margin-top: 2.4em;
    color: #fff;
  }
  .prose h3 {
    font-size: 22px;
    letter-spacing: -0.03em;
    margin-top: 2em;
    color: var(--color-purple);
  }
  .prose a {
    color: var(--color-purple);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #4a3f7a;
  }
  .prose ul,
  .prose ol {
    padding-left: 1.3em;
  }
  .prose li + li {
    margin-top: 0.5em;
  }
  .prose blockquote {
    border-left: 2px solid var(--color-purple);
    padding-left: 1.2em;
    color: var(--color-muted);
    font-style: normal;
  }
  .prose img {
    max-width: 100%;
    border-radius: 8px;
  }
  /* 표는 모바일에서 가로 스크롤 (넘침 방지) */
  .prose table {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 14px;
    -webkit-overflow-scrolling: touch;
  }
  .prose thead th {
    text-align: left;
    color: #fff;
    font-weight: 400;
    white-space: nowrap;
  }
  .prose th,
  .prose td {
    border: 1px solid #222;
    padding: 8px 12px;
    letter-spacing: -0.01em;
  }
  .prose td {
    color: var(--color-muted);
  }
  /* 코드블록도 가로 넘침 방지 (긴 라인) */
  .prose pre {
    max-width: 100%;
  }
  .prose hr {
    border: none;
    border-top: 1px solid #1e1e1e;
    margin: 2.4em 0;
  }
  .prose strong {
    color: #fff;
    font-weight: 400;
    background: linear-gradient(transparent 60%, #2a2350 60%);
  }
</style>
