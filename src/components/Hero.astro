---
// 인터랙티브 타이포 hero.
// "ZERO LOG"를 텍스처로 구운 뒤, 잘게 쪼갠 평면 정점을 마우스 근처에서
// 밀어올려 휘어짐/찢어짐(RGB split)을 만든다. Three.js는 hero에서만 로드.
---

<section class="hero" aria-label="ZERO LOG">
  <canvas id="hero-canvas" aria-hidden="true"></canvas>

  <!-- 폴백 & SEO용 실제 텍스트. JS가 붙으면 시각적으로 숨김. -->
  <div class="hero-fallback" id="hero-fallback">
    <h1 class="display hero-title">ZERO<br />LOG</h1>
  </div>

  <p class="hero-sub">
    3년 치 트러블슈팅과 판단의 기록. <span class="accent">AI가 못 쓰는 1차 데이터.</span>
  </p>
  <div class="hero-scroll" aria-hidden="true">↓ scroll</div>
</section>

<style>
  .hero {
    position: relative;
    height: 100svh;
    min-height: 560px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 44px;
    overflow: hidden;
  }
  #hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
  .hero-fallback {
    position: relative;
    z-index: 1;
  }
  .hero-title {
    font-size: clamp(72px, 18vw, 240px);
    letter-spacing: -0.09em;
    line-height: 0.88;
    margin: 0;
  }
  /* WebGL 활성화되면 폴백 텍스트 숨김 (canvas가 대체) */
  .hero[data-gl='on'] .hero-fallback {
    visibility: hidden;
  }
  .hero-sub {
    position: relative;
    z-index: 2;
    margin-top: 2rem;
    max-width: 34ch;
    color: var(--color-muted);
    font-size: clamp(15px, 1.4vw, 19px);
    letter-spacing: -0.02em;
    line-height: 1.5;
  }
  .hero-sub .accent {
    color: var(--color-purple);
  }
  .hero-scroll {
    position: absolute;
    bottom: 28px;
    left: 44px;
    color: var(--color-dim);
    font-size: 13px;
    letter-spacing: -0.01em;
    animation: bob 2.4s ease-in-out infinite;
  }
  @keyframes bob {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.5;
    }
    50% {
      transform: translateY(6px);
      opacity: 1;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-scroll {
      animation: none;
    }
  }
  @media (max-width: 640px) {
    .hero {
      padding: 0 20px;
    }
    .hero-scroll {
      left: 20px;
    }
  }
</style>

<script>
  import * as THREE from 'three';

  (() => {
  const section = document.querySelector<HTMLElement>('.hero')!;
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // "ZERO / LOG"를 텍스트 블록 비율(≈4:3)에 맞는 캔버스에 그려 텍스처로 사용.
  // 2:1처럼 옆으로 넓은 캔버스를 쓰면 세로 화면에서 글자가 납작하게 눌린다.
  const TEX_W = 1536;
  const TEX_H = 1152;
  const TEX_ASPECT = TEX_W / TEX_H; // ≈1.33
  function makeTextTexture() {
    const c = document.createElement('canvas');
    c.width = TEX_W;
    c.height = TEX_H;
    const ctx = c.getContext('2d')!;
    ctx.clearRect(0, 0, c.width, c.height);
    ctx.fillStyle = '#ffffff';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    ctx.font = '400 500px "Inter Variable", Inter, system-ui, sans-serif';
    // @ts-ignore letterSpacing는 최신 브라우저 지원
    ctx.letterSpacing = '-40px';
    ctx.fillText('ZERO', c.width / 2, c.height * 0.3);
    ctx.fillText('LOG', c.width / 2, c.height * 0.72);
    const tex = new THREE.CanvasTexture(c);
    tex.minFilter = THREE.LinearFilter;
    tex.anisotropy = 4;
    return tex;
  }

  // 텍스처 비율을 보존한 채 뷰포트 안에 맞춰 넣는다 (가로/세로 화면 모두 자연스럽게).
  function fitPlane() {
    const availW = 2 * aspect * 0.92;
    const availH = 2 * 0.62;
    let w = availW;
    let h = w / TEX_ASPECT;
    if (h > availH) {
      h = availH;
      w = h * TEX_ASPECT;
    }
    return { w, h };
  }

  let renderer: THREE.WebGLRenderer;
  try {
    renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  } catch {
    // WebGL 불가 → 폴백 텍스트 그대로 노출
    return;
  }

  section.dataset.gl = 'on';

  const scene = new THREE.Scene();
  let aspect = section.clientWidth / section.clientHeight;
  const camera = new THREE.OrthographicCamera(-aspect, aspect, 1, -1, 0.1, 10);
  camera.position.z = 2;

  const uniforms = {
    uTex: { value: makeTextTexture() },
    uMouse: { value: new THREE.Vector2(-10, -10) },
    uTime: { value: 0 },
    uReduced: { value: prefersReduced ? 1 : 0 },
  };

  const fit0 = fitPlane();
  const geo = new THREE.PlaneGeometry(fit0.w, fit0.h, 180, 90);
  const mat = new THREE.ShaderMaterial({
    uniforms,
    transparent: true,
    vertexShader: /* glsl */ `
      uniform vec2 uMouse;
      uniform float uTime;
      uniform float uReduced;
      varying vec2 vUv;
      varying float vInfl;
      void main() {
        vUv = uv;
        vec3 p = position;
        float d = distance(p.xy, uMouse);
        float infl = 1.0 / (1.0 + d * d * 9.0);
        // 마우스 근처를 밀어올리며 물결(찢어짐) 생성
        float ripple = sin(d * 22.0 - uTime * 4.0);
        p.z += infl * 0.45 * ripple;
        p.xy += normalize(p.xy - uMouse + 0.0001) * infl * 0.06;
        // 유휴 상태 잔물결
        float idle = (1.0 - uReduced) * 0.018 * sin(p.x * 3.0 + uTime * 1.2);
        p.z += idle;
        vInfl = infl;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(p, 1.0);
      }
    `,
    fragmentShader: /* glsl */ `
      uniform sampler2D uTex;
      varying vec2 vUv;
      varying float vInfl;
      void main() {
        // 왜곡 강도에 비례한 RGB split → "찢어짐" 질감
        vec2 off = vec2(vInfl * 0.012, 0.0);
        float r = texture2D(uTex, vUv + off).a;
        float g = texture2D(uTex, vUv).a;
        float b = texture2D(uTex, vUv - off).a;
        float a = max(r, max(g, b));
        if (a < 0.02) discard;
        vec3 base = vec3(1.0);
        vec3 purple = vec3(0.717, 0.674, 0.988); // #B7ACFC
        vec3 col = mix(base, purple, clamp(vInfl * 1.4, 0.0, 1.0));
        col.r *= mix(1.0, 1.2, r);
        col.b *= mix(1.0, 1.2, b);
        gl_FragColor = vec4(col, a);
      }
    `,
  });

  const mesh = new THREE.Mesh(geo, mat);
  scene.add(mesh);

  function resize() {
    aspect = section.clientWidth / section.clientHeight;
    camera.left = -aspect;
    camera.right = aspect;
    camera.updateProjectionMatrix();
    mesh.geometry.dispose();
    const fit = fitPlane();
    mesh.geometry = new THREE.PlaneGeometry(fit.w, fit.h, 180, 90);
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    renderer.setPixelRatio(dpr);
    renderer.setSize(section.clientWidth, section.clientHeight, false);
  }
  resize();
  window.addEventListener('resize', resize);

  // 마우스 → 평면 좌표
  const target = new THREE.Vector2(-10, -10);
  section.addEventListener('pointermove', (e) => {
    const rect = section.getBoundingClientRect();
    const nx = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    const ny = -(((e.clientY - rect.top) / rect.height) * 2 - 1);
    target.set(nx * aspect, ny);
  });
  section.addEventListener('pointerleave', () => target.set(-10, -10));

  // 키보드: 방향키로도 포커스 이동 (인터랙션 접근성)
  window.addEventListener('keydown', (e) => {
    const step = 0.15;
    if (e.key === 'ArrowLeft') target.x -= step;
    else if (e.key === 'ArrowRight') target.x += step;
    else if (e.key === 'ArrowUp') target.y += step;
    else if (e.key === 'ArrowDown') target.y -= step;
  });

  const clock = new THREE.Clock();
  let raf = 0;
  function tick() {
    uniforms.uTime.value = clock.getElapsedTime();
    // 부드럽게 따라가기
    uniforms.uMouse.value.lerp(target, 0.12);
    renderer.render(scene, camera);
    raf = requestAnimationFrame(tick);
  }
  tick();

  // 탭 비활성 시 렌더 정지 (배터리 절약)
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) cancelAnimationFrame(raf);
    else tick();
  });
  })();
</script>
