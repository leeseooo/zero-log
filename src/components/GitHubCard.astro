---
// 옵션 C: 잔디 격자 없이 @user + 스탯(repos/followers) + 프로필 링크만.
// 토큰 불필요. 스탯은 GitHub 공식 REST /users/{login} (공개, 인증 불필요).
// 카드 전체가 github.com/{user} 로 가는 링크다.
const username = import.meta.env.GITHUB_USERNAME ?? 'leeseooo';

let followers: number | null = null;
let repos: number | null = null;
let name: string | null = null;

try {
  const res = await fetch(`https://api.github.com/users/${username}`, {
    headers: { Accept: 'application/vnd.github+json' },
  });
  if (res.ok) {
    const u = await res.json();
    followers = u.followers ?? null;
    repos = u.public_repos ?? null;
    name = u.name ?? null;
  }
} catch (e) {
  console.warn('[GitHubCard] 스탯 fetch 실패, 링크만 렌더:', e);
}
---

<a class="gh-card" href={`https://github.com/${username}`} target="_blank" rel="noopener">
  <div class="gh-top">
    <span class="gh-user">@{username}</span>
    {name && <span class="gh-name">{name}</span>}
  </div>

  {
    (repos != null || followers != null) && (
      <div class="gh-stats">
        {repos != null && (
          <span>
            <b>{repos}</b> repos
          </span>
        )}
        {followers != null && (
          <span>
            <b>{followers}</b> followers
          </span>
        )}
      </div>
    )
  }

  <span class="gh-link">프로필 보기 →</span>
</a>

<style>
  .gh-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--color-panel);
    border: 1px solid #1c1c1c;
    padding: 22px 24px;
    color: var(--color-fg);
    transition: border-color 0.2s;
  }
  .gh-card:hover {
    border-color: var(--color-purple);
    color: var(--color-fg);
  }
  .gh-card:hover .gh-link {
    color: var(--color-purple);
  }
  .gh-top {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .gh-user {
    font-size: 18px;
    letter-spacing: -0.04em;
  }
  .gh-name {
    font-size: 13px;
    color: var(--color-dim);
    letter-spacing: -0.01em;
  }
  .gh-stats {
    display: flex;
    gap: 18px;
    color: var(--color-muted);
    font-size: 14px;
    letter-spacing: -0.02em;
  }
  .gh-stats b {
    color: var(--color-fg);
    font-weight: 400;
  }
  .gh-link {
    color: var(--color-dim);
    font-size: 14px;
    letter-spacing: -0.02em;
    transition: color 0.2s;
  }
</style>
