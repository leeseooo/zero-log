---
// 토큰 없이(PAT 불필요) 빌드타임에 GitHub 활동을 끌어와 Contra 퍼플 스케일로 렌더.
//  - 잔디: github-contributions-api (공개, 인증 불필요)
//  - 스탯: GitHub 공식 REST /users/{login} (공개, 인증 불필요 · 시간당 60회면 충분)
// 서드파티(잔디)가 죽으면 잔디만 폴백되고 스탯/링크는 유지된다.
const username = import.meta.env.GITHUB_USERNAME ?? 'leeseooo';

type Day = { count: number; date: string; level: number };
type Stats = {
  total: number | null;
  followers: number | null;
  repos: number | null;
  weeks: Day[][];
} | null;

let stats: Stats = null;

try {
  const [contribRes, userRes] = await Promise.all([
    fetch(`https://github-contributions-api.jogruber.de/v4/${username}?y=last`),
    fetch(`https://api.github.com/users/${username}`, {
      headers: { Accept: 'application/vnd.github+json' },
    }),
  ]);

  const contrib = contribRes.ok ? await contribRes.json() : null;
  const user = userRes.ok ? await userRes.json() : null;

  // 최근 ~20주(140일)만 컴팩트하게
  const days: Day[] = (contrib?.contributions ?? []).slice(-140);
  const weeks: Day[][] = [];
  for (let i = 0; i < days.length; i += 7) weeks.push(days.slice(i, i + 7));

  const total =
    contrib?.total?.lastYear ??
    (contrib?.total ? Object.values(contrib.total as Record<string, number>).at(-1) : null);

  stats = {
    total: total ?? null,
    followers: user?.followers ?? null,
    repos: user?.public_repos ?? null,
    weeks,
  };
} catch (e) {
  console.warn('[GitHubCard] fetch 실패, 링크 폴백으로 렌더:', e);
}

const hasGrid = !!stats && stats.weeks.length > 0;
---

<a class="gh-card" href={`https://github.com/${username}`} target="_blank" rel="noopener">
  <div class="gh-head">
    <span class="gh-user">@{username}</span>
    {stats?.total != null && <span class="gh-total">최근 1년 {stats.total.toLocaleString()} contributions</span>}
  </div>

  {
    hasGrid ? (
      <>
        <div class="gh-grid" role="img" aria-label={`최근 활동 ${stats!.total ?? ''} contributions`}>
          {stats!.weeks.map((week) => (
            <div class="gh-col">
              {week.map((day) => (
                <span class="gh-cell" data-lv={day.level} title={`${day.date}: ${day.count}`} />
              ))}
            </div>
          ))}
        </div>
        <div class="gh-stats">
          {stats!.repos != null && (
            <span>
              <b>{stats!.repos}</b> repos
            </span>
          )}
          {stats!.followers != null && (
            <span>
              <b>{stats!.followers}</b> followers
            </span>
          )}
        </div>
      </>
    ) : (
      <div class="gh-empty">GitHub 프로필 보기 →</div>
    )
  }
</a>

<style>
  .gh-card {
    display: block;
    background: var(--color-panel);
    border: 1px solid #1c1c1c;
    padding: 20px 22px;
    color: var(--color-fg);
    transition: border-color 0.2s;
  }
  .gh-card:hover {
    border-color: var(--color-purple);
    color: var(--color-fg);
  }
  .gh-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 14px;
  }
  .gh-user {
    letter-spacing: -0.03em;
    font-size: 15px;
  }
  .gh-total {
    color: var(--color-dim);
    font-size: 12px;
    letter-spacing: -0.01em;
    text-align: right;
  }
  .gh-grid {
    display: flex;
    gap: 3px;
  }
  .gh-col {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
  }
  .gh-cell {
    aspect-ratio: 1;
    border-radius: 2px;
    background: #1a1a1a;
  }
  .gh-cell[data-lv='1'] {
    background: #3b2f66;
  }
  .gh-cell[data-lv='2'] {
    background: #5a45a0;
  }
  .gh-cell[data-lv='3'] {
    background: #8a76d8;
  }
  .gh-cell[data-lv='4'] {
    background: var(--color-purple);
  }
  .gh-stats {
    display: flex;
    gap: 18px;
    margin-top: 14px;
    color: var(--color-muted);
    font-size: 13px;
    letter-spacing: -0.02em;
  }
  .gh-stats b {
    color: var(--color-fg);
    font-weight: 400;
  }
  .gh-empty {
    color: var(--color-purple);
    font-size: 15px;
    letter-spacing: -0.02em;
  }
</style>
